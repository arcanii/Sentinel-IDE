# Build output (CMake/Ninja); regenerated by scripts\build.bat
/build/

# Compiler/linker artifacts anywhere (snc/MSVC) — e.g. examples\target\
target/
*.o
*.obj
*.exe
*.lib
*.a
*.pdb
*.exp
*.ilk

# Sealed projects, signing keys, and unsealed working copies — never commit
*.sealed
*.key
*-unsealed/

# Agent/editor tooling and local config (not part of the project)
/.claude/
/_bmad/

# OS / editor cruft
Thumbs.db
desktop.ini
*.user
